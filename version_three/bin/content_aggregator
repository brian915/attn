#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'

$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))
require 'content_aggregator'

options = {
  config_path: nil
}

option_parser = OptionParser.new do |parser|
  parser.banner = 'Usage: content_aggregator [options]'

  parser.on('-c', '--config PATH', 'Path to YAML config file') do |value|
    options[:config_path] = value
  end

  parser.on('-h', '--help', 'Show help') do
    puts parser
    exit 0
  end
end

option_parser.parse!

runner = ContentAggregator::Runner.new(config_path: options[:config_path])
runner.run
